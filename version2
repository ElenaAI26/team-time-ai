        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #020617;
        }

        .slide {
            display: none;
            height: 100vh;
            width: 100vw;
            padding: 2.5rem;
            transition: opacity 0.5s ease-in-out;
        }

        .slide.active {
            display: flex;
            flex-direction: column;
            animation: fadeIn 0.8s ease-out forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
        }

        .gradient-text {
            background: linear-gradient(to r, #ffffff 0%, rgba(255, 255, 255, 0.6) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Background Mesh Graphics */
        .mesh-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: 
                radial-gradient(at 0% 0%, rgba(30, 58, 138, 0.4) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(124, 58, 237, 0.3) 0px, transparent 50%),
                radial-gradient(at 50% 100%, rgba(8, 145, 178, 0.2) 0px, transparent 50%);
        }

        .grid-bg {
            background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            position: absolute;
            inset: 0;
            z-index: -1;
        }

        /* Loading Animation */
        #loader {
            position: fixed;
            inset: 0;
            background: #020617;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease-out;
        }

        .loader-circle {
            width: 54px;
            height: 54px;
            border: 4px solid rgba(255, 255, 255, 0.05);
            border-top-color: #22d3ee;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Navigation Dots */
        .dot-nav.active {
            width: 28px;
            background: #22d3ee;
            box-shadow: 0 0 12px rgba(34, 211, 238, 0.5);
        }

        [contenteditable]:focus {
